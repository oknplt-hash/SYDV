{
    "rewrites": [
        {
            "source": "/api/python_fetch",
            "destination": "/api/python_fetch.py"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}